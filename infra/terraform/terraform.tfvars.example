aws_region  = "us-west-2"
project_name = "ott-inventory-ai" # Existing AWS resource prefix. Keep stable unless doing a planned migration.
environment = "mvp"

allowed_origins = [
  "https://otokistocksense.pages.dev",
  "https://ott-inventory-ai.pages.dev",
  "http://localhost:3000",
  "http://127.0.0.1:3000"
]

# Leave empty to derive a globally unique bucket name from project, account, and region.
raw_import_bucket_name = ""
raw_file_retention_days = 365

# Strongly recommended for the <$10/month MVP.
enable_budget      = true
budget_email       = "you@example.com"
monthly_budget_usd = 10

# Keep disabled until the buyer demo needs scheduled refreshes.
enable_refresh_schedule = false

# Store real auth values in SSM Parameter Store or set them manually on Lambda.
# Do not put secret values in terraform.tfvars; Terraform state can expose them.
auth_username_parameter_name   = "/inventory-ai/mvp/auth/username"
auth_password_parameter_name   = "/inventory-ai/mvp/auth/password"
auth_secret_key_parameter_name = "/inventory-ai/mvp/auth/secret-key"

# Optional OpenAI-backed AI query layer. Store the actual key only in SSM.
openai_api_key_parameter_name = "/inventory-ai/mvp/openai/api-key"
openai_model                  = "gpt-5-mini"
ai_query_enabled              = true

tags = {
  Owner = "stocksense"
}
