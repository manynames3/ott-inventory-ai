POSTGRES_DB=inventory_ai
POSTGRES_USER=inventory_ai_local
POSTGRES_PASSWORD=replace_with_a_local_dev_password
DATABASE_URL=postgresql+psycopg://inventory_ai_local:replace_with_a_local_dev_password@db:5432/inventory_ai
TENANT_ID=default

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_AUTH_MODE=password
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/login
NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000/login
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTH_ENABLED=true
AUTH_USERNAME=planner@example.com
AUTH_PASSWORD=replace_with_a_demo_or_pilot_password
AUTH_ROLE=approver
# Optional multi-user pilot auth. Prefer this over single-user auth when showing approvals.
# Example:
# AUTH_USERS_JSON={"planner@example.com":{"password":"replace_me","role":"planner"},"ops-manager@example.com":{"password":"replace_me","role":"approver"}}
AUTH_USERS_JSON=
AUTH_SECRET_KEY=replace_with_a_long_random_signing_secret
AUTH_TOKEN_TTL_MINUTES=720

AI_QUERY_ENABLED=true
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
OPENAI_API_KEY_PARAMETER_NAME=/inventory-ai/mvp/openai/api-key

SUPPLIER_LEAD_TIME_DAYS=30
FORECAST_INTERVAL_SECONDS=3600
IMPORT_QUEUE_DIR=/app/import_queue

AWS_REGION=us-west-2
AWS_S3_RAW_IMPORT_BUCKET=
AWS_S3_IMPORT_PREFIX=inventory-ai/raw-imports
SCHEDULED_IMPORT_PREFIXES=inventory-ai/raw-imports/scheduled/,inventory-ai/raw-imports/sftp/
AWS_S3_AUDIT_ARCHIVE_BUCKET=
RAW_FILE_RETENTION_DAYS=365
AUDIT_EVENT_RETENTION_DAYS=180
IMPORT_STATUS_RETENTION_DAYS=90
AUDIT_ARCHIVE_RETENTION_DAYS=2555
SIEM_HTTP_ENDPOINT=
ALERT_SNS_TOPIC_ARN=
AWS_DYNAMODB_RECORDS_TABLE=inventory_ai_records
AWS_DYNAMODB_VIEWS_TABLE=inventory_ai_views
AWS_DYNAMODB_IMPORTS_TABLE=inventory_ai_imports
ALLOW_DEMO_SEED=false
